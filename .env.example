# Copy to .env (or set in your deployment env). Used by the Next.js API routes
# (/api/maps-key, /api/geocode, /api/solar) and never bundled into client code.
# Needs Maps JavaScript, Geocoding, and Solar APIs enabled. Restrict by HTTP referrer.
GOOGLE_SOLAR_API_KEY=

# Optional: a Google Map ID enables Advanced Markers (removes the deprecated
# Marker warning). Leave blank to use the classic marker.
GOOGLE_MAP_ID=

# ML roof segmentation (server-side only). HUGGINGFACE_API_TOKEN authenticates,
# HF_SEGMENT_URL is your deployed segmentation Space/Endpoint (see huggingface-space/).
# Also requires the "Maps Static API" enabled on the Google key.
HUGGINGFACE_API_TOKEN=
HF_SEGMENT_URL=
